# Telegram bot runtime only. Never expose this file to the frontend.
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
SUPABASE_URL="https://your-project-ref.supabase.co"
# Use only in this local bot runtime. Never expose this in the frontend.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-secret-or-service-role-key"

BOT_TIMEZONE="America/Sao_Paulo"
# Default: run reminder checks once per day. Use 15 for local testing.
REMINDER_INTERVAL_MINUTES="1440"
